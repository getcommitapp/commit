{
  "expo": {
    "name": "commit",
    "slug": "commit",
    "version": "0.4.1",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "commit",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#a1ffeb"
    },
    "ios": {
      "bundleIdentifier": "com.getcommitapp.commit",
      "supportsTablet": true,
      "usesAppleSignIn": true,
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "We use your location to validate challenges when you're at the target place.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "We use your location in the background to validate challenges even when the app is closed.",
        "UIBackgroundModes": ["location"]
      }
    },
    "android": {
      "package": "com.getcommitapp.commit",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "permissions": [
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION",
        "ACCESS_BACKGROUND_LOCATION"
      ],
      "foregroundService": {
        "notificationTitle": "Commit is running",
        "notificationContent": "Tracking your location for challenges"
      },
      "googleMapsApiKey": "${GOOGLE_MAPS_API_KEY}",
      "edgeToEdgeEnabled": true
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-apple-authentication",
      [
        "expo-location",
        {
          "isIosBackgroundLocationEnabled": true
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "a3dac6e9-1931-4680-bafd-d3050bb42072"
      }
    },
    "owner": "getcommitapp"
  }
}
